+def _sample_mesh_vertices(mesh, point_count):
+    vertices = np.asarray(mesh.vertices, dtype=np.float32)
+    if len(vertices) == 0:
+        return np.zeros((point_count, 3), dtype=np.float32)
+    indices = np.linspace(0, len(vertices) - 1, point_count, dtype=np.int64)
+    return vertices[indices]
+
+
+def _build_visualization_payload(task, hand_states, object_states, lift_m, success):
+    """Reconstruct official hand/object geometry for one success and one failure.
+
+    The compact point-cloud payload is stored beside the raw 28-D hand and 7-D
+    object states.  Rendering is intentionally performed offline so every case
+    shares the exact same camera, bounds, colours, and frame rate.
+    """
+    success_ids = np.flatnonzero(success)
+    failure_ids = np.flatnonzero(~success)
+    candidates = []
+    if len(success_ids):
+        candidates.append(('success', int(success_ids[np.argmax(lift_m[success_ids].max(axis=1))])))
+    if len(failure_ids):
+        candidates.append(('failure', int(failure_ids[np.argmax(lift_m[failure_ids].max(axis=1))])))
+
+    payload = {}
+    descriptions = []
+    frame_count = hand_states.shape[1]
+    for case_name, trajectory_id in candidates:
+        trajectory_lift = lift_m[trajectory_id]
+        lift_threshold = max(0.01, float(trajectory_lift.max()) * 0.80)
+        lift_candidates = np.flatnonzero(trajectory_lift >= lift_threshold)
+        lift_step = int(lift_candidates[0]) if len(lift_candidates) else int(np.argmax(trajectory_lift))
+        contact_threshold = max(0.003, float(trajectory_lift.max()) * 0.10)
+        contact_candidates = np.flatnonzero(trajectory_lift >= contact_threshold)
+        contact_step = int(contact_candidates[0]) if len(contact_candidates) else max(1, frame_count // 3)
+        key_steps = [0, contact_step, lift_step, frame_count - 1]
+        sampled_steps = np.unique(np.concatenate([
+            np.linspace(0, frame_count - 1, min(32, frame_count), dtype=np.int64),
+            np.asarray(key_steps, dtype=np.int64),
